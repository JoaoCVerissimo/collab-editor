{
  "name": "@collab-editor/database",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "migrate": "knex migrate:latest --knexfile knexfile.ts",
    "migrate:rollback": "knex migrate:rollback --knexfile knexfile.ts",
    "seed": "knex seed:run --knexfile knexfile.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint migrations/ knexfile.ts"
  },
  "dependencies": {
    "knex": "^3.1.0",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
